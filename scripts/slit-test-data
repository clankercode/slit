#!/usr/bin/env python3
import sys, time, random, math

COLORS = [196, 202, 208, 214, 220, 226, 190, 154, 118, 82, 46, 47, 48, 49, 51, 45, 39, 33, 27, 21, 57, 93, 129, 165]
CHUNKS = "▓▒░█▄▀▐▌●◆★◇◈⬟⬡◉◎⬢⬣◈◆▸▹▽△♤♧♡♢♠♣♥♦"

def fg(c, bold=False):
    b = "1;" if bold else ""
    return f"\033[{b}38;5;{c}m"

def rgb(r, g, b):
    return f"\033[38;2;{r};{g};{b}m"

def reset():
    return "\033[0m"

def waterfall_line(i, width):
    phase = i * 0.07
    color_idx = int((math.sin(phase) * 0.5 + 0.5) * (len(COLORS) - 1))
    c = COLORS[color_idx % len(COLORS)]

    bar_len = int((math.sin(phase * 1.3) * 0.5 + 0.5) * (width - 20)) + 5
    bar_len = min(bar_len, width - 2)

    r = int(80 + 175 * (math.sin(phase) * 0.5 + 0.5))
    g = int(80 + 175 * (math.sin(phase + 2.1) * 0.5 + 0.5))
    b_val = int(80 + 175 * (math.sin(phase + 4.2) * 0.5 + 0.5))

    chunk = random.choice(CHUNKS)
    bar = chunk * bar_len
    line_num = f"{fg(c, bold=True)}{i:>5}{reset()}"
    sep = f"{fg(c)}│{reset()}"
    colored_bar = f"{rgb(r, g, b_val)}{bar}{reset()}"

    spinner_frames = "⣾⣽⣻⢿⡿⣟⣯⣷"
    sp = spinner_frames[i % len(spinner_frames)]

    return f"{line_num} {sep} {colored_bar} {sep} {fg(c)}{sp}{reset()}"

def banner(text, color):
    w = len(text) + 6
    top = f"{fg(color, bold=True)}╔{'═' * w}╗{reset()}"
    mid = f"{fg(color, bold=True)}║  {text}  ║{reset()}"
    bot = f"{fg(color, bold=True)}╚{'═' * w}╝{reset()}"
    return f"{top}\n{mid}\n{bot}"

def phase_rain(rows):
    for i in range(rows):
        ci = int((i / rows) * (len(COLORS) - 1))
        c = COLORS[ci]
        width = random.randint(10, 60)
        chunk = random.choice(CHUNKS)
        yield f"{fg(c)}{chunk * width}{reset()}"
        time.sleep(0.02)

def phase_matrix(rows):
    chars = "01ｱｲｳｴｵｶｷｸｹｺ"
    for i in range(rows):
        line = ""
        for _ in range(random.randint(30, 70)):
            ch = random.choice(chars)
            brightness = random.randint(100, 255)
            line += f"\033[38;2;0;{brightness};0m{ch}"
        line += reset()
        yield line
        time.sleep(0.03)

def phase_gradient(rows):
    for i in range(rows):
        parts = []
        for j in range(60):
            hue = (i * 3 + j * 5) % 360
            s, l = 0.9, 0.55
            c = (1 - abs(2 * l - 1)) * s
            x = c * (1 - abs((hue / 60) % 2 - 1))
            m = l - c / 2
            if hue < 60: r, g, b = c, x, 0
            elif hue < 120: r, g, b = x, c, 0
            elif hue < 180: r, g, b = 0, c, x
            elif hue < 240: r, g, b = 0, x, c
            elif hue < 300: r, g, b = x, 0, c
            else: r, g, b = c, 0, x
            parts.append(f"\033[38;2;{int((r+m)*255)};{int((g+m)*255)};{int((b+m)*255)}m█")
        yield "".join(parts) + reset()
        time.sleep(0.025)

def phase_waterfall(rows):
    for i in range(rows):
        yield waterfall_line(i, 72)
        time.sleep(0.015)

def main():
    width = 72

    print(banner("~ slit test data ~", 51))
    time.sleep(0.3)

    print(f"\033[3m{fg(246)}A colorful waterfall of streaming output for testing slit.{reset()}\n")
    time.sleep(0.5)

    phases = [
        ("rain", phase_rain),
        ("matrix", phase_matrix),
        ("gradient", phase_gradient),
        ("waterfall", phase_waterfall),
    ]

    while True:
        for name, gen in phases:
            print(f"\n{fg(255)}── {name} {'─' * (width - len(name) - 5)}{reset()}")
            time.sleep(0.2)
            rows = random.randint(30, 80)
            for line in gen(rows):
                print(line)
                sys.stdout.flush()
            time.sleep(0.3)

if __name__ == "__main__":
    main()
